{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "noEmitOnError": true
  },
  "include": [
    "src/cli.ts",
    "src/orchestrator.ts",
    "src/control-server.ts",
    "src/db.ts",
    "src/rpc.ts"
  ],
  "exclude": [
    "src/peer-extension.ts",
    "src/index.ts",
    "index.ts",
    "tests/**/*",
    "node_modules",
    "dist"
  ]
}