#!/usr/bin/env node
/**
 * @pi-agent-mesh — CLI entry point.
 *
 * Thin wrapper that imports the compiled CLI from dist/cli.js. The
 * actual logic lives there; this script exists so `npm install -g
 * @pi-agent-mesh` makes the `mesh` command available on PATH.
 *
 * Auto-resolves the dist/ directory whether we're installed as an npm
 * package (../dist/cli.js from this file's location) or running from a
 * checkout (../../dist/cli.js from scripts/ during dev).
 */

import { spawn } from "node:child_process";
import { existsSync } from "node:fs";
import { dirname, resolve, join } from "node:path";
import { fileURLToPath, pathToFileURL } from "node:url";

const __dirname = dirname(fileURLToPath(import.meta.url));

// Look for dist/cli.js relative to this file:
//   installed:        <pkg>/bin/mesh  →  <pkg>/dist/cli.js
//   dev (scripts/):   <root>/bin/mesh →  <root>/dist/cli.js
const candidates = [
	resolve(__dirname, "..", "dist", "cli.js"),
	resolve(__dirname, "..", "..", "dist", "cli.js"),
];

let cliEntry = null;
for (const p of candidates) {
	if (existsSync(p)) {
		cliEntry = p;
		break;
	}
}

if (!cliEntry) {
	console.error(
		`@pi-agent-mesh: dist/cli.js not found. Run \`npm run build\` first.`,
	);
	process.exit(1);
}

await import(pathToFileURL(cliEntry).href).then((m) => {
	if (typeof m.main === "function") return m.main();
	console.error(
		`@pi-agent-mesh: dist/cli.js does not export a main() function`,
	);
	process.exit(1);
});